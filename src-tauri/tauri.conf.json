{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WhatsappUltraFast",
  "version": "0.1.1",
  "identifier": "com.ramdanolii14.whatsappultrafast",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Whatsapp Ultra Fast",
        "url": "https://web.whatsapp.com",
        "width": 1024,
        "height": 720,
        "userAgent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36 WhatsApp/2.2412.54"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}